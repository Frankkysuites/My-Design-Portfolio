{
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/portfolio/dist/$1"
    }
  ],
  "buildCommand": "cd artifacts/portfolio && pnpm run build",
  "outputDirectory": "artifacts/portfolio/dist",
  "installCommand": "pnpm install"
}
